{% macro icon(name) %}
<svg class="icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
  {% if name == "mail" %}
    <path d="M4 6h16v12H4z"></path>
    <path d="m4 7 8 6 8-6"></path>
  {% elif name == "user" %}
    <path d="M20 21a8 8 0 0 0-16 0"></path>
    <circle cx="12" cy="8" r="4"></circle>
  {% elif name == "tools" %}
    <path d="m14.7 6.3-5.4 5.4"></path>
    <path d="M12.2 8.8 15 11.6"></path>
    <path d="m3 21 6.1-6.1"></path>
    <path d="M8.7 5.2a3.5 3.5 0 1 0 5.1 4.8l6-6"></path>
    <path d="M12.8 18.5a3.5 3.5 0 1 0 4.8-5.1l-6 6"></path>
  {% elif name == "badge" %}
    <circle cx="12" cy="8" r="5"></circle>
    <path d="m8.5 12.5-1.5 8 5-3 5 3-1.5-8"></path>
  {% elif name == "certificate" %}
    <rect x="4" y="3" width="16" height="18" rx="2"></rect>
    <path d="M8 7h8"></path>
    <path d="M8 11h5"></path>
    <path d="m14.5 16 1.5 1 2-3"></path>
  {% elif name == "chart" %}
    <path d="M4 19V5"></path>
    <path d="M4 19h16"></path>
    <path d="m7 15 4-4 3 3 5-7"></path>
  {% elif name == "users" %}
    <circle cx="9" cy="8" r="3"></circle>
    <path d="M3 20a6 6 0 0 1 12 0"></path>
    <path d="M16 11a3 3 0 0 0 0-6"></path>
    <path d="M17 20a5 5 0 0 0-3-4.6"></path>
  {% elif name == "heart" %}
    <path d="M20.8 8.6c0 5.2-8.8 10.4-8.8 10.4S3.2 13.8 3.2 8.6A4.6 4.6 0 0 1 12 6.4a4.6 4.6 0 0 1 8.8 2.2z"></path>
  {% elif name == "search" %}
    <circle cx="11" cy="11" r="6"></circle>
    <path d="m16 16 4 4"></path>
  {% elif name == "file" %}
    <path d="M14 2H7a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7z"></path>
    <path d="M14 2v5h5"></path>
    <path d="M9 13h6"></path>
    <path d="M9 17h6"></path>
  {% elif name == "cloud" %}
    <path d="M17.5 19H8a5 5 0 1 1 .9-9.9 6 6 0 0 1 11.6 2.4A3.8 3.8 0 0 1 17.5 19z"></path>
    <path d="M8 19h9.5"></path>
  {% elif name == "monitor" %}
    <rect x="3" y="4" width="18" height="12" rx="2"></rect>
    <path d="M8 20h8"></path>
    <path d="M12 16v4"></path>
  {% elif name == "github" %}
    <path d="M12 2a10 10 0 0 0-3.2 19.5c.5.1.7-.2.7-.5v-2c-2.9.6-3.5-1.2-3.5-1.2-.5-1.1-1.1-1.4-1.1-1.4-.9-.6.1-.6.1-.6 1 .1 1.6 1.1 1.6 1.1.9 1.5 2.4 1.1 3 .8.1-.7.4-1.1.7-1.4-2.3-.3-4.8-1.2-4.8-5.1 0-1.1.4-2.1 1.1-2.8-.1-.3-.5-1.4.1-2.8 0 0 .9-.3 2.9 1.1a9.9 9.9 0 0 1 5.2 0c2-1.4 2.9-1.1 2.9-1.1.6 1.4.2 2.5.1 2.8.7.8 1.1 1.7 1.1 2.8 0 4-2.4 4.8-4.8 5.1.4.3.8 1 .8 2v2.7c0 .3.2.6.8.5A10 10 0 0 0 12 2z"></path>
  {% elif name == "rss" %}
    <path d="M4 11a9 9 0 0 1 9 9"></path>
    <path d="M4 4a16 16 0 0 1 16 16"></path>
    <circle cx="5" cy="19" r="1"></circle>
  {% endif %}
</svg>
{% endmacro %}

<header class="site-header">
  <a class="brand" href="/">
    <span class="brand-mark"></span>
    <span class="brand-name">Rozaki</span>
    <span class="brand-copy">中小企業のIT基盤伴走支援</span>
  </a>
  <nav class="site-nav" aria-label="メインナビゲーション">
    <a href="#top" class="is-active">ホーム</a>
    <a href="#service">サービス</a>
    <a href="#profile">プロフィール</a>
    <a href="#work">実績・取り組み</a>
    <a href="https://tech.royozaki.net/tech/jp/">ブログ</a>
    <a class="nav-cta" href="#contact">{{ icon("mail") | safe }} お問い合わせ</a>
  </nav>
</header>

<section class="hero" id="top">
  <div class="hero-grid">
    <div class="hero-copy">
      <h1>IT基盤の不安を<span class="no-break">整理し、</span><br class="desktop-break">安定して運用できる状態へ。</h1>
      <p class="lead">
        AWS、Linuxサーバー、ネットワーク、監視、バックアップ、セキュリティを横断して、
        中小企業のWebアプリ・業務システムをインフラ面から支援します。
      </p>
      <p class="lead lead-sub">
        サーバー更改、AWS活用、CI/CD整備、監視・バックアップ改善、セキュリティ対策、
        運用改善まで、現状整理から改善提案、実装・運用まで伴走します。
      </p>

      <div class="hero-meta">
        <span>AWS</span>
        <span>Linux</span>
        <span>Network</span>
        <span>Security</span>
        <span>CI/CD</span>
        <span>Monitoring</span>
        <span>Backup</span>
      </div>

      <div class="hero-actions">
        <a class="btn btn-primary" href="#contact">{{ icon("mail") | safe }} お問い合わせはこちら</a>
        <a class="text-link" href="#service">サービス内容を見る <span>→</span></a>
      </div>
    </div>

    <div class="hero-visual">
      <img src="/assets/images/profile-bright.png" alt="Rozakiのプロフィール写真" class="profile-image">
    </div>
  </div>
</section>

<section class="section service-flow" id="service">
  <div class="service-summary">
    <h2>中小企業のIT基盤伴走支援</h2>
    <p>
      現状の整理から、改善方針の設計、実装・運用、
      継続的な改善まで。
    </p>
    <p>
      IT基盤の課題に寄り添い、安定した運用と
      事業の成長を支えます。
    </p>
    <div class="line-illustration" aria-hidden="true">
      <span></span><span></span><span></span><span></span>
    </div>
  </div>

  <div class="flow-area">
    <h3 class="flow-title">支援の進め方</h3>
    <div class="flow-grid">
      <article class="flow-card">
        <span class="step">01</span>
        <div class="icon-box">{{ icon("search") | safe }}</div>
        <h4>現状整理・ヒアリング</h4>
        <p>課題や要望を整理し、現状の構成や運用を把握します。</p>
      </article>
      <article class="flow-card">
        <span class="step">02</span>
        <div class="icon-box">{{ icon("file") | safe }}</div>
        <h4>改善提案・設計</h4>
        <p>課題に対する改善方針を整理し、最適な構成や方針を設計します。</p>
      </article>
      <article class="flow-card">
        <span class="step">03</span>
        <div class="icon-box">{{ icon("cloud") | safe }}</div>
        <h4>実装・構築</h4>
        <p>設計に基づき、AWSやサーバー環境の構築・設定を行います。</p>
      </article>
      <article class="flow-card">
        <span class="step">04</span>
        <div class="icon-box">{{ icon("monitor") | safe }}</div>
        <h4>運用・改善</h4>
        <p>監視や運用体制を整え、継続的に改善を進めます。</p>
      </article>
      <article class="flow-card">
        <span class="step">05</span>
        <div class="icon-box">{{ icon("users") | safe }}</div>
        <h4>伴走・相談</h4>
        <p>困ったときに相談できるパートナーとして、長く伴走します。</p>
      </article>
    </div>
  </div>
</section>

